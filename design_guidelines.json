  "implementation_guide": {
    "setup_steps": [
      "Initialize React project with Vite (JavaScript)",
      "Install Tailwind CSS and configured shadcn/ui",
      "Install lucide-react, framer-motion, clsx, tailwind-merge",
      "Create components/ui folder and add Button, Card, etc.",
      "Implement the Layout component with Navbar and Footer",
      "Build the Hero section with the grid background image",
      "Build the Projects Grid using CSS Grid (Bento)",
      "Ensure all text has sufficient contrast (WCAG AA)"
    ],
    "universal_guidelines": [
      "Use 'Outfit' for all headings (h1-h3)",
      "Use 'Inter' for body text",
      "Use 'JetBrains Mono' for any code snippets or tech tags",
      "Primary Action Color: #002FA7 (International Klein Blue)",
      "Do not use gradients for text",
      "Ensure mobile responsiveness (stack grids on small screens)",
      "Add hover states to all interactive elements (transform: translateY(-2px))"
    ]
  }
}