{
  "design_system": {
    "typography": {
      "font_family": {
        "heading": "Outfit, sans-serif",
        "body": "Inter, sans-serif",
        "mono": "JetBrains Mono, monospace"
      },
      "scale": {
        "h1": "text-5xl md:text-7xl font-bold tracking-tight",
        "h2": "text-4xl md:text-5xl font-semibold tracking-tight",
        "h3": "text-2xl md:text-3xl font-medium",
        "body": "text-base md:text-lg leading-relaxed text-slate-600 dark:text-slate-300",
        "caption": "text-sm text-slate-500 uppercase tracking-widest"
      }
    },
    "colors": {
      "palette": {
        "primary": {
          "DEFAULT": "#002FA7",
          "hover": "#001F70",
          "foreground": "#FFFFFF"
        },
        "background": {
          "light": "#FFFFFF",
          "dark": "#0A0A0A"
        },
        "surface": {
          "light": "#F5F5F7",
          "dark": "#121212"
        },
        "accent": {
          "DEFAULT": "#004E64",
          "light": "#E0F2F1"
        },
        "text": {
          "primary": "#0F172A",
          "secondary": "#475569",
          "muted": "#94A3B8"
        }
      },
      "theme_strategy": "light-preferred-with-dark-toggle"
    },
    "layout": {
      "grid_system": "Bento Grid (CSS Grid)",
      "spacing": {
        "container": "max-w-7xl mx-auto px-6 md:px-12",
        "section_gap": "py-24 md:py-32",
        "element_gap": "gap-6 md:gap-8"
      },
      "border_radius": {
        "default": "rounded-none",
        "card": "rounded-sm",
        "button": "rounded-full"
      }
    },
    "components": {
      "ui_library": "shadcn/ui",
      "required_components": [
        "Button",
        "Card",
        "Badge",
        "Separator",
        "ScrollArea",
        "Tooltip",
        "Sheet",
        "NavigationMenu"
      ],
      "custom_components": [
        "ProjectCard (Bento Style)",
        "TechStackTicker",
        "HeroSection (Split Layout)",
        "ContactForm (Simple)"
      ]
    },
    "motion": {
      "library": "framer-motion",
      "animations": {
        "fade_up": {
          "initial": { "opacity": 0, "y": 20 },
          "animate": { "opacity": 1, "y": 0 },
          "transition": { "duration": 0.5, "ease": "easeOut" }
        },
        "stagger_children": {
          "animate": { "transition": { "staggerChildren": 0.1 } }
        },
        "hover_lift": {
          "whileHover": { "y": -5, "transition": { "duration": 0.2 } }
        }
      }
    }
  },
